# OpenAI API key used for AI analysis (default --ai-provider). Separate from any
# ChatGPT/Codex CLI login -- requires its own billing at platform.openai.com.
OPENAI_API_KEY=

# Anthropic API key, only needed if you pass --ai-provider anthropic. Requires its
# own billing at console.anthropic.com (separate from any consumer chat plan).
ANTHROPIC_API_KEY=

# AWS credentials are read from the standard AWS CLI chain (aws configure / env vars /
# instance profile). Set these only if you want to override the default profile/region.
AWS_PROFILE=default
AWS_REGION=us-west-2

# GCP credentials are read from Application Default Credentials (gcloud auth
# application-default login / GOOGLE_APPLICATION_CREDENTIALS). Set this only if you want
# to override the default/discovered project.
GOOGLE_CLOUD_PROJECT=

# Azure credentials are read via DefaultAzureCredential (az login / env vars / managed
# identity). Set this only if you want to override the default subscription.
AZURE_SUBSCRIPTION_ID=
